# 集成测试环境变量示例（AC-5）
# 复制为 .env.test 并按本地环境填写

# AI 补位倒计时（秒）；设 0 则加入后立即补位，方便 demo / 集成测试
AI_FILL_DELAY=0

# 鉴权模式：stub = 跳过真实 OAuth，直接按 code 创建测试用户
AUTH_MODE=stub

# JWT 签名密钥（与 server 保持一致即可，测试环境可用固定值）
JWT_SECRET=test_secret_change_me

# MySQL 连接（需本地或 Docker 实例）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=game_db

# Redis 连接（需本地或 Docker 实例）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# 服务端口（集成测试时 @colyseus/testing 使用 2568，dev 启动默认 2567）
PORT=2567
